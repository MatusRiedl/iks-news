# Required: your Discord bot token from the Discord Developer Portal
DISCORD_TOKEN=your_discord_bot_token_here

# Optional: Gemini API key for primary AI processing
GEMINI_API_KEY=

# Defaults for scheduled posting
DEFAULT_TIMEZONE=Europe/Bratislava
DEFAULT_POST_TIME=15:00
DATA_DIR=data

# Optional: numeric Discord server ID for faster slash-command sync in one test server
DISCORD_TEST_GUILD_ID=

# Optional: Groq API key used as fallback when Gemini is unavailable
GROQ_API_KEY=

# Optional: supported values are sk or en
DEFAULT_LANGUAGE=sk
